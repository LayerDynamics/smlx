# ----------------------------------------------------------------------------
*.log
*.log.*
logs/
*.sql
*.sqlite
*.sqlite3
*.db

# ----------------------------------------------------------------------------
# OS Specific
# ----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ----------------------------------------------------------------------------
# Node.js (for any web interfaces or tools)
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
package-lock.json
yarn.lock

# ----------------------------------------------------------------------------
# Environment Variables and Secrets
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
.envrc
secrets/
*.key
*.pem
*.p12
credentials.json
service-account.json

# ----------------------------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
.cache/

# ----------------------------------------------------------------------------
# Project Specific
# ----------------------------------------------------------------------------
# Reference implementations (keep in repo per CLAUDE.md)
# resources/  # Commented out - keep reference implementations

# Server/API
.fastapi_cache/
*.pid
celerybeat-schedule
celerybeat.pid

# Audio files (keep small test files, ignore large collections)
audio/recordings/
audio/output/
*.wav
*.mp3
*.flac
!audio/test/*.wav

# Vision files (keep small test images, ignore large datasets)
images/raw/
images/processed/
*.tiff
*.tif
!images/test/*.jpg
!images/test/*.png

# Generated files
generated/
outputs/
results/
experiments/

# Local configuration overrides
config.local.yml
config.local.json
settings.local.py

# User-specific files
TODO.txt
NOTES.md
scratch/
playground/

# ----------------------------------------------------------------------------
# Git LFS (Large File Storage)
# ----------------------------------------------------------------------------
# Track large files but ignore local LFS cache
.git/lfs/

# ============================================================================
# End of .gitignore
# ============================================================================
.benchmarks
__pycache__
.pytest_cache
.ruff_cache
.vscode
resources
dist
node_modules
